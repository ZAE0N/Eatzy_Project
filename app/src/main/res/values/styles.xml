<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 로고 폰트: HTML 시안의 Outfit(스카이 화면)·Nunito(룰렛 화면).
         가변폰트에 textStyle bold(합성 볼드)로 굵게. 한글 글리프가 없으므로 로고("Eatzy"/"E")에만 사용. -->
    <style name="LogoOutfit">
        <item name="android:fontFamily">@font/outfit</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LogoNunito">
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 룰렛 메뉴 라벨: 칸 전체 크기로 깔고 상단 중앙에 글자를 둔 뒤,
         각 칸 각도만큼 회전시켜 방사형으로 배치한다(룰렛판과 함께 회전). -->
    <style name="RouletteLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">top|center_horizontal</item>
        <item name="android:paddingTop">38dp</item>
        <item name="android:textColor">@color/text_navy</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 입력 필드 라벨 -->
    <style name="FieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 식당 리스트 아이템 -->
    <style name="RestItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:background">@color/white</item>
    </style>

    <style name="RestThumb">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@drawable/bg_thumb</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="RestInfo">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="RestName">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">3dp</item>
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RestMeta">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gray_400</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- 사이드바 메뉴 -->
    <style name="MenuGroupLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">6dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textColor">@color/gray_400</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="MenuItemActive" parent="MenuItem">
        <item name="android:background">@drawable/bg_chip_on</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 커뮤니티 게시글 카드 -->
    <style name="PostCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@color/white</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="PostHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="Avatar">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_avatar</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PostAuthor">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="PostDate">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gray_300</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PostTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PostPreview">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:textColor">@color/gray_400</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="PostFooter">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/gray_400</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PostDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/gray_100</item>
    </style>

    <!-- 댓글 -->
    <style name="CommentItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="CAvatar">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_avatar</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CBody">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="CAuthor">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- 니즈 설정 -->
    <style name="NeedsSectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Chip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:paddingHorizontal">13dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ChipOn" parent="Chip">
        <item name="android:background">@drawable/bg_chip_on</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
