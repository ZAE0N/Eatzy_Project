<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".LocationPickerActivity">

    <!-- 상단바: 닫기 / 주소 검색 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_box"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/gray_700"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/et_address"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input"
            android:hint="🔍 주소 입력 (예: 인하로 100)"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/gray_700"
            android:textColorHint="@color/gray_400"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/btn_search"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_send_btn"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="검색"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_100" />

    <!-- 안내: 지도를 탭해서 위치 지정 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_lt"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:text="지도를 탭하거나 주소를 검색해 위치를 지정하세요"
        android:textColor="@color/primary_dk"
        android:textSize="12sp" />

    <fragment
        android:id="@+id/map_fragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 선택 위치 표시 + 등록 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/txt_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_chip_on"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:padding="16dp"
            android:text="📍 선택된 위치가 없습니다"
            android:textColor="@color/primary_dk"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="이 위치로 등록"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
