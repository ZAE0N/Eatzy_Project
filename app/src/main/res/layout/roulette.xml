<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/roulette_bg"
    android:orientation="vertical"
    tools:context=".RouletteActivity">

    <!-- 헤더: 로고 + 프로필 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- 로고: Eatzy (마지막 y만 하늘색은 Activity에서 Spannable 처리) -->
        <TextView
            android:id="@+id/logo_eatzy"
            style="@style/LogoNunito"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Eatzy"
            android:textColor="@color/text_navy"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/btn_add_menu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="＋ 메뉴"
            android:textColor="@color/roulette_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_profile_icon"
            android:gravity="center"
            android:text="👤"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 메인 콘텐츠 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="8dp"
            android:text="오늘 점심은 뭘 먹을까요?"
            android:textColor="@color/text_navy"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="고민은 저희가 할게요! 가볍게 돌려주세요."
            android:textColor="@color/gray_500"
            android:textSize="15sp" />

        <!-- 룰렛: 크기는 RouletteActivity 에서 화면 폭에 비례해 동적 지정(반응형) -->
        <FrameLayout
            android:id="@+id/wheel_container"
            android:layout_width="280dp"
            android:layout_height="300dp">

            <!-- 룰렛판 + 메뉴 라벨: 이 그룹 전체가 함께 회전한다 -->
            <FrameLayout
                android:id="@+id/wheel_group"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="bottom|center_horizontal">

                <!-- 색 룰렛판 -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="룰렛판"
                    android:src="@drawable/ic_roulette_wheel" />

                <!-- 6개 메뉴 라벨 (각 칸 중앙 각도로 회전 배치, 칸 순서: 0~5).
                     텍스트는 RouletteActivity 에서 필터된 후보 카테고리로 동적 설정. -->
                <TextView android:id="@+id/label_0" style="@style/RouletteLabel" android:rotation="30" android:text="한식" />
                <TextView android:id="@+id/label_1" style="@style/RouletteLabel" android:rotation="90" android:text="중식" />
                <TextView android:id="@+id/label_2" style="@style/RouletteLabel" android:rotation="150" android:text="일식" />
                <TextView android:id="@+id/label_3" style="@style/RouletteLabel" android:rotation="210" android:text="양식" />
                <TextView android:id="@+id/label_4" style="@style/RouletteLabel" android:rotation="270" android:text="분식" />
                <TextView android:id="@+id/label_5" style="@style/RouletteLabel" android:rotation="330" android:text="치킨" />
            </FrameLayout>

            <!-- 화살표 핀 (고정) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:text="▼"
                android:textColor="@color/text_navy"
                android:textSize="26sp" />

            <!-- 중앙 축: 크기·위치도 휠 크기에 비례해 동적 지정 -->
            <View
                android:id="@+id/wheel_hub"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="118dp"
                android:background="@drawable/bg_roulette_center" />
        </FrameLayout>

        <!-- 당첨 결과 -->
        <TextView
            android:id="@+id/txt_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="버튼을 눌러 메뉴를 골라보세요!"
            android:textColor="@color/gray_500"
            android:textSize="17sp" />
    </LinearLayout>

    <!-- 룰렛 돌리기 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="40dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_spin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spin_btn"
            android:paddingVertical="18dp"
            android:text="룰렛 돌리기"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 결과가 나오면 표시: 해당 메뉴로 맛집 찾기 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_find"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_outline"
            android:paddingVertical="16dp"
            android:text="이 메뉴로 맛집 찾기"
            android:textAllCaps="false"
            android:textColor="@color/roulette_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
