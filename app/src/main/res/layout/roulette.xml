<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/roulette_bg"
    android:orientation="vertical"
    tools:context=".RouletteActivity">

    <!-- 헤더: 로고 + 프로필 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- 로고: Eatzy (마지막 y만 하늘색) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Eatzy"
            android:textColor="@color/text_navy"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_profile_icon"
            android:gravity="center"
            android:text="👤"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 메인 콘텐츠 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="8dp"
            android:text="오늘 점심은 뭘 먹을까요?"
            android:textColor="@color/text_navy"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="고민은 저희가 할게요! 가볍게 돌려주세요."
            android:textColor="@color/gray_500"
            android:textSize="15sp" />

        <!-- 룰렛 -->
        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="300dp">

            <!-- 화살표 핀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:text="▼"
                android:textColor="@color/text_navy"
                android:textSize="26sp" />

            <!-- 룰렛판 -->
            <ImageView
                android:id="@+id/wheel"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="bottom|center_horizontal"
                android:contentDescription="룰렛판"
                android:src="@drawable/ic_roulette_wheel" />

            <!-- 중앙 축 -->
            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="118dp"
                android:background="@drawable/bg_roulette_center" />
        </FrameLayout>
    </LinearLayout>

    <!-- 룰렛 돌리기 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="40dp">

        <Button
            android:id="@+id/btn_spin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spin_btn"
            android:paddingVertical="18dp"
            android:text="룰렛 돌리기"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
