<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 상단바: ☰(사이드바) 왼쪽 상단 / 로고+앱이름 정중앙
         ConstraintLayout 이라 로고가 항상 화면 정중앙에 온다. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="@dimen/topbar_padding_h"
        android:paddingTop="@dimen/topbar_padding_top"
        android:paddingBottom="@dimen/topbar_padding_bottom">

        <!-- 왼쪽 상단: 사이드바 버튼 -->
        <TextView
            android:id="@+id/btn_menu"
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box"
            android:gravity="center"
            android:text="☰"
            android:textSize="@dimen/icon_box_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 정중앙: 로고(E) + 앱 이름(Eatzy) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                style="@style/LogoOutfit"
                android:layout_width="@dimen/logo_chip_size"
                android:layout_height="@dimen/logo_chip_size"
                android:background="@drawable/bg_logo_chip"
                android:gravity="center"
                android:text="E"
                android:textColor="@color/white"
                android:textSize="@dimen/logo_chip_text" />

            <TextView
                style="@style/LogoOutfit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Eatzy"
                android:textColor="@color/gray_900"
                android:textSize="@dimen/title_text" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <!-- 맛집 추천 큰 카드 -->
            <LinearLayout
                android:id="@+id/card_recommend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_big"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="@dimen/card_big_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.85"
                    android:text="2.1 — 맛집 추천"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="오늘 점심, 뭐 먹지?"
                    android:textColor="@color/white"
                    android:textSize="@dimen/card_big_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.85"
                    android:text="내 주변 맛집을 찾아\n룰렛으로 결정해봐요!"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_pill_white"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="🍽️ 추천 받기"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 하단 2개 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_needs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/card_gap"
                    android:background="@drawable/bg_card_small"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="@dimen/card_small_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="⚙️"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="2.2"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="니즈 설정"
                        android:textColor="@color/gray_900"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="음식 취향과 가격대 설정"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_community"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_gap"
                    android:background="@drawable/bg_card_small"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="@dimen/card_small_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="💬"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="2.3"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="커뮤니티"
                        android:textColor="@color/gray_900"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="맛집 리뷰 &amp; 메뉴 토크"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 룰렛 FAB -->
            <TextView
                android:id="@+id/fab_roulette"
                android:layout_width="@dimen/fab_size"
                android:layout_height="@dimen/fab_size"
                android:layout_gravity="end"
                android:background="@drawable/bg_fab"
                android:elevation="8dp"
                android:gravity="center"
                android:text="🌀"
                android:textSize="@dimen/fab_text" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
