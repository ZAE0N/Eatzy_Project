<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".NeedsSettingsActivity">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_icon_box"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/gray_700"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="니즈 설정"
                android:textColor="@color/gray_900"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 취향에 맞는 맛집만 추천받아요"
            android:textColor="@color/gray_400"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 음식 종류 -->
            <TextView style="@style/NeedsSectionTitle" android:text="🍱 음식 종류" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_food"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:chipSpacingHorizontal="7dp"
                app:chipSpacingVertical="7dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <TextView style="@style/ChipOn" android:text="한식" />
                <TextView style="@style/Chip" android:text="일식" />
                <TextView style="@style/ChipOn" android:text="양식" />
                <TextView style="@style/Chip" android:text="중식" />
                <TextView style="@style/ChipOn" android:text="분식" />
                <TextView style="@style/Chip" android:text="패스트푸드" />
                <TextView style="@style/Chip" android:text="아시안" />
            </com.google.android.material.chip.ChipGroup>

            <!-- 주재료 -->
            <TextView style="@style/NeedsSectionTitle" android:text="🌾 주재료" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_ingredient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:chipSpacingHorizontal="7dp"
                app:chipSpacingVertical="7dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <TextView style="@style/ChipOn" android:text="밥" />
                <TextView style="@style/Chip" android:text="빵" />
                <TextView style="@style/ChipOn" android:text="면" />
                <TextView style="@style/Chip" android:text="무탄수" />
            </com.google.android.material.chip.ChipGroup>

            <!-- 가격대 -->
            <TextView style="@style/NeedsSectionTitle" android:text="💰 가격대" />

            <SeekBar
                android:id="@+id/seek_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="27000"
                android:progress="12000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3,000원"
                    android:textColor="@color/gray_400"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="~15,000원"
                    android:textColor="@color/gray_400"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="30,000원"
                    android:textColor="@color/gray_400"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- 알레르기 -->
            <TextView style="@style/NeedsSectionTitle" android:text="🚨 알레르기 / 기피 메뉴" />

            <EditText
                android:id="@+id/et_allergy"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_input"
                android:hint="알레르기 없으면 직접 적어주세요"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textColor="@color/gray_700"
                android:textColorHint="@color/gray_300"
                android:textSize="13sp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="예: 갑각류, 땅콩, 돼지고기 등"
                android:textColor="@color/gray_400"
                android:textSize="11sp" />
        </LinearLayout>
    </ScrollView>

    <!-- 저장 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_primary"
            android:text="설정 저장"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
