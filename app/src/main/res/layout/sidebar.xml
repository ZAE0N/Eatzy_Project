<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="horizontal"
    tools:context=".SidebarActivity">

    <!-- 왼쪽 메뉴 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="68"
        android:orientation="vertical">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <TextView
                style="@style/LogoOutfit"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_logo_chip"
                android:gravity="center"
                android:text="E"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                style="@style/LogoOutfit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eatzy"
                android:textColor="@color/gray_900"
                android:textSize="16sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_100" />

        <!-- 메뉴 목록 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView style="@style/MenuGroupLabel" android:text="기본" />

                <TextView
                    android:id="@+id/menu_recommend"
                    style="@style/MenuItemActive"
                    android:text="🍽️   맛집 추천" />

                <TextView
                    android:id="@+id/menu_needs"
                    style="@style/MenuItem"
                    android:text="⚙️   니즈 설정" />

                <TextView style="@style/MenuGroupLabel" android:text="기타" />

                <TextView android:id="@+id/menu_community" style="@style/MenuItem" android:text="💬   커뮤니티" />

                <TextView android:id="@+id/menu_wishlist" style="@style/MenuItem" android:text="🔖   위시리스트" />
            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_100" />

        <!-- 푸터: 홈화면 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <TextView
                android:id="@+id/btn_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_on"
                android:padding="12dp"
                android:text="🏠   홈화면"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gray_100" />

    <!-- 오른쪽 탭 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="32"
        android:orientation="vertical"
        android:paddingTop="44dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="기\n본"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_100" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="외\n부\n메\n뉴"
            android:textColor="@color/gray_400"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
