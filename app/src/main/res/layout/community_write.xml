<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".CommunityWriteActivity">

    <!-- 상단바: 닫기 / 제목 / 등록 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_box"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/gray_700"
            android:textSize="15sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="글쓰기"
            android:textColor="@color/gray_900"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_submit"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="등록"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_100" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_input"
                android:hint="제목"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textColor="@color/gray_900"
                android:textColorHint="@color/gray_400"
                android:textSize="15sp"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="160dp"
                android:background="@drawable/bg_input"
                android:gravity="top|start"
                android:hint="내용을 입력하세요"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/gray_700"
                android:textColorHint="@color/gray_400"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <!-- 첨부 이미지 미리보기(있을 때만 표시) -->
            <ImageView
                android:id="@+id/img_preview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_thumb"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="첨부 이미지" />

            <!-- 등록된 위치 표시(있을 때만) -->
            <TextView
                android:id="@+id/txt_place"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_on"
                android:drawablePadding="6dp"
                android:padding="12dp"
                android:text="📍 위치"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- 첨부 도구: 사진 / 위치 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_add_image"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center"
                    android:text="🖼️ 사진 추가"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_add_location"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="center"
                    android:text="📍 위치 등록"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
